# Local development uses the same file shape as production.
# Set DEBUG=false for hardened production behavior.
DEBUG=true

# Local ports used by deploy/compose.dev.yml.
APP_PORT=8080
API_PORT=3001

# Public MONDAY application hostname served by Caddy in production.
MONDAY_DOMAIN=monday.example.com

# Public Authentik hostname served by Caddy in production.
AUTH_DOMAIN=auth.example.com

# Email used by Caddy ACME/Let's Encrypt account for certificate operations.
CADDY_EMAIL=ops@example.com

# Caddy container image tag. Keep pinned so certificate/runtime behavior is predictable.
CADDY_IMAGE=caddy:2-alpine

# Authentik release tag. Must match the supported server release you want to run.
AUTHENTIK_TAG=2026.2.2

# Authentik server/worker image repository. Override only if you mirror images internally.
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server

# Authentik log level. Use trace only temporarily while debugging forward-auth or flows.
AUTHENTIK_LOG_LEVEL=info

# PostgreSQL database name used only by Authentik.
PG_DB=authentik

# PostgreSQL username used only by Authentik.
PG_USER=authentik

# PostgreSQL password for the Authentik database user.
PG_PASS=replace-with-a-generated-password

# Core Authentik secret key.
AUTHENTIK_SECRET_KEY=replace-with-a-generated-secret-key

# Optional bootstrap email for the initial akadmin superuser.
AUTHENTIK_BOOTSTRAP_EMAIL=owner@example.com

# Optional bootstrap password for the built-in akadmin account.
AUTHENTIK_BOOTSTRAP_PASSWORD=replace-with-a-generated-bootstrap-password

# Optional bootstrap API token for akadmin.
AUTHENTIK_BOOTSTRAP_TOKEN=replace-with-a-generated-bootstrap-token

# Owner username created by scripts/bootstrap-authentik.sh and granted access to MONDAY.
MONDAY_OWNER_USERNAME=monday-owner

# Owner display name created by scripts/bootstrap-authentik.sh.
MONDAY_OWNER_NAME="MONDAY Owner"

# Owner email shown in /api/me and Authentik.
MONDAY_OWNER_EMAIL=owner@example.com

# Owner password for manual login testing and initial operator access.
MONDAY_OWNER_PASSWORD=replace-with-a-generated-owner-password

# Optional negative-test username that should authenticate successfully but be denied.
MONDAY_DENIED_USERNAME=monday-denied

# Optional negative-test display name for the denied user.
MONDAY_DENIED_NAME="MONDAY Denied User"

# Optional negative-test email for the denied user.
MONDAY_DENIED_EMAIL=denied@example.com

# Optional negative-test password for the denied user.
MONDAY_DENIED_PASSWORD=replace-with-a-generated-denied-password

# Brand title shown on the Authentik login page after bootstrap.
MONDAY_AUTH_BRAND_TITLE="MONDAY Auth"

# Optional outbound SMTP host for recovery links and email notifications.
AUTHENTIK_EMAIL__HOST=

# Optional outbound SMTP port.
AUTHENTIK_EMAIL__PORT=587

# Optional outbound SMTP username.
AUTHENTIK_EMAIL__USERNAME=

# Optional outbound SMTP password.
AUTHENTIK_EMAIL__PASSWORD=

# Optional sender address used by Authentik emails.
AUTHENTIK_EMAIL__FROM=

# Whether Authentik should use TLS when sending email.
AUTHENTIK_EMAIL__USE_TLS=true
