{
  "name": "monday",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc --noEmit && vite build",
    "build:api": "npm --prefix server run build",
    "dev": "docker compose -f deploy/compose.dev.yml up --build",
    "deploy:prod": "docker compose --env-file .env -f deploy/compose.production.yml up -d --build",
    "deploy:timeweb": "docker compose --env-file deploy/timeweb.env -f deploy/compose.timeweb.yml up -d --build"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
