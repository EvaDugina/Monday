# Internal loopback port exposed only for host nginx proxy_pass.
MONDAY_APP_PORT=18080

# Public path prefix that nginx forwards to the container.
APP_BASE_PATH=/monday

# Start with false during plain HTTP bootstrap. Switch to true after HTTPS-by-IP is enabled.
SESSION_COOKIE_SECURE=false

# Single local user for the built-in login form.
MONDAY_AUTH_USERNAME=admin
MONDAY_AUTH_NAME=MONDAY

# Replace these placeholders before first start:
# node scripts/generate-auth-hash.mjs "your-password"
MONDAY_AUTH_PASSWORD_SALT=__GENERATE_ME_WITH_scripts_generate-auth-hash__
MONDAY_AUTH_PASSWORD_HASH=__GENERATE_ME_WITH_scripts_generate-auth-hash__
MONDAY_SESSION_SECRET=__GENERATE_ME_WITH_scripts_generate-auth-hash__
